{
  "info": {
    "name": "RentNest API",
    "description": "API collection for the RentNest Backend Project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Tenant\",\n  \"email\": \"tenant@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"TENANT\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{token}}"}],
            "url": {"raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/properties", "host": ["{{base_url}}"], "path": ["api", "properties"]}
          }
        },
        {
          "name": "Get Property By Id",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/properties/ID_HERE", "host": ["{{base_url}}"], "path": ["api", "properties", "ID_HERE"]}
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/categories", "host": ["{{base_url}}"], "path": ["api", "categories"]}
          }
        }
      ]
    },
    {
      "name": "Rentals (Tenant)",
      "item": [
        {
          "name": "Submit Rental Request",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "{{token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"ID_HERE\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/rentals", "host": ["{{base_url}}"], "path": ["api", "rentals"]}
          }
        },
        {
          "name": "Get My Rentals",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{token}}"}],
            "url": {"raw": "{{base_url}}/api/rentals", "host": ["{{base_url}}"], "path": ["api", "rentals"]}
          }
        },
        {
          "name": "Get Rental By Id",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{token}}"}],
            "url": {"raw": "{{base_url}}/api/rentals/ID_HERE", "host": ["{{base_url}}"], "path": ["api", "rentals", "ID_HERE"]}
          }
        }
      ]
    },
    {
      "name": "Landlord Operations",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "{{token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Beautiful Apartment\",\n  \"description\": \"Spacious 2 bedroom apartment\",\n  \"price\": 1200,\n  \"location\": \"New York\",\n  \"categoryId\": \"ID_HERE\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/landlord/properties", "host": ["{{base_url}}"], "path": ["api", "landlord", "properties"]}
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "{{token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1300\n}"
            },
            "url": {"raw": "{{base_url}}/api/landlord/properties/ID_HERE", "host": ["{{base_url}}"], "path": ["api", "landlord", "properties", "ID_HERE"]}
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "{{token}}"}],
            "url": {"raw": "{{base_url}}/api/landlord/properties/ID_HERE", "host": ["{{base_url}}"], "path": ["api", "landlord", "properties", "ID_HERE"]}
          }
        },
