          "name": "Get Rental Requests",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "{{token}}"}],
            "url": {"raw": "{{base_url}}/api/landlord/requests", "host": ["{{base_url}}"], "path": ["api", "landlord", "requests"]}
          }
        },
        {
          "name": "Update Request Status",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "{{token}}"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/landlord/requests/ID_HERE", "host": ["{{base_url}}"], "path": ["api", "landlord", "requests", "ID_HERE"]}
          }
        }
      ]
    },
